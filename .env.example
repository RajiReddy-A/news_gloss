# Required for live news and Hugging Face inference
CURRENTS_API_KEY=replace_with_your_currents_api_key
HF_TOKEN=hf_replace_with_your_token

# Optional configuration
HF_MODEL=Qwen/Qwen3-8B
HF_PROVIDER=auto
HF_MODEL_SUFFIX=
FETCH_INTERVAL_MIN=30
TOP_N_PREGEN=10
MAX_ARTICLES=5
SUPPORTED_LANGS=hi,mr,ta,te,bn,kn,ml
CACHE_DIR=/tmp/cache
